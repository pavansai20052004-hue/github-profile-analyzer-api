PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=github_profile_analyzer

# Optional but recommended to improve GitHub API rate limits.
GITHUB_TOKEN=

# Maximum repositories to inspect per profile analysis.
ANALYSIS_MAX_REPOS=300

# Use * for local development, or set your frontend/deployment origin.
CORS_ORIGIN=*
